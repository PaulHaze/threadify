# Threadify environment config — copy to .env and fill in your own values.
# .env is gitignored. NEVER commit real keys.

# --- Spotify (create an app at https://developer.spotify.com/dashboard) ---
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret

# Redirect URI must be a loopback literal — Spotify no longer allows "localhost".
# Must exactly match the URI registered in your Spotify app settings.
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8888/callback

# --- LLM (default provider: Anthropic / Claude) ---
# Get a key from https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key

# Model used for extraction. Claude Haiku is plenty for this task.
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
